---
import { Icon } from 'astro-icon/components';

const cards = [
  { rot: -18, ty: 28, label: 'guidance', image: `${import.meta.env.BASE_URL}guidence.png` },
  { rot: -6, ty: 4, label: 'stretch', image: `${import.meta.env.BASE_URL}stretch.png` },
  { rot: 6, ty: 4, label: 'movement', image: `${import.meta.env.BASE_URL}movement.png` },
  { rot: 18, ty: 28, label: 'rest', image: `${import.meta.env.BASE_URL}rest.png` },
];
const mid = (cards.length - 1) / 2;
---

<section class="relative overflow-hidden bg-black text-white">
  <div class="relative mx-auto max-w-6xl px-6 pt-28 pb-8 md:px-10 md:pt-36 md:pb-12 lg:px-14">
    <div class="grid items-end gap-8 md:grid-cols-12">
      <div class="reveal md:col-span-10">
        <h2 class="intro-heading font-serif tracking-tight">
          Your mental <em class="italic">wellbeing.</em>
        </h2>
        <p class="mt-6 max-w-md text-[15px] leading-relaxed text-pretty text-white/65 md:text-base">
          Asme provides care &amp; professional mindfulness support for your journey.
        </p>
      </div>
      <div class="reveal flex md:col-span-2 md:justify-end" style="transition-delay: 180ms;">
        <a
          href="#"
          class="liquid-glass inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium whitespace-nowrap text-white transition-colors hover:bg-white/5"
        >
          <span>Who We Are</span>
          <Icon name="lucide:arrow-up-right" size={14} stroke-width={2} />
        </a>
      </div>
    </div>
  </div>

  <div
    class="fan-stage relative flex items-center justify-center overflow-hidden bg-black py-16 md:py-20"
  >
    <div class="fan-inner relative flex h-full w-full max-w-5xl items-center justify-center">
      <div class="fan-cards relative flex items-end justify-center">
        {
          cards.map((c, i) => (
            <div
              class="fan-card absolute"
              style={`--rot: ${c.rot}deg; --ty: ${c.ty}px; --offset: ${i - mid}; z-index: ${10 - Math.abs(i - mid)};`}
            >
              <div class:list={["liquid-glass relative flex h-[300px] w-[210px] items-end overflow-hidden rounded-[22px] p-3 md:h-[400px] md:w-[280px]", { 'placeholder-stripes': !c.image }]}>
                {c.image && (
                  <img
                    src={c.image}
                    alt={c.label}
                    class="absolute inset-0 h-full w-full object-cover"
                  />
                )}
                <div class="fan-card-overlay pointer-events-none absolute inset-0" />
                <span class="font-mono relative text-[9px] tracking-[0.25em] text-white/55 uppercase">
                  [ {c.label} ]
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .intro-heading {
    font-size: clamp(1.9rem, 5.5vw, 4.6rem);
    line-height: 1.05;
  }

  .fan-cards {
    width: 0;
  }

  /* fan-stage height and spread defined per breakpoint in CSS
     (removed from Tailwind classes to avoid specificity conflicts) */
  .fan-stage {
    --progress: 0;
    --spread: 240px;
    height: 85vh;
    min-height: 600px;
  }

  .fan-card {
    top: 50%;
    left: 50%;
    transform-origin: center center;
    transform:
      translate(
        calc(-50% + var(--offset) * var(--spread) * var(--progress)),
        -50%
      )
      rotate(calc(var(--rot) * var(--progress)))
      translateY(calc(var(--ty) * var(--progress)))
      scale(calc(0.92 + 0.08 * var(--progress)));
    transition: transform 120ms linear;
  }

  .fan-card-overlay {
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.04) 0%,
      transparent 30%,
      rgba(0, 0, 0, 0.45) 100%
    );
  }

  /* Tablet (768–1023px): reduce spread and card sizes */
  @media (max-width: 1023px) {
    .fan-stage {
      --spread: 165px;
      height: 80vh;
      min-height: 500px;
    }

    .fan-card > div {
      height: 310px !important;
      width: 215px !important;
    }
  }

  /* Large mobile / small tablet landscape (640–767px) */
  @media (max-width: 767px) {
    .fan-stage {
      --spread: 145px;
      height: 75vh;
      min-height: 480px;
    }
  }

  /* Mobile (< 640px): sticky container + horizontal slide driven by vertical scroll */
  @media (max-width: 639px) {
    /* Allow sticky child to work — clip doesn't create a scroll container */
    section,
    .fan-stage {
      overflow: clip !important;
    }

    .fan-stage {
      height: 250vh;
      min-height: unset;
      display: block;
      padding: 0;
    }

    /* Sticky viewport-height panel */
    .fan-inner {
      position: sticky;
      top: 0;
      height: 100vh;
      width: 100%;
      max-width: 100%;
      overflow: clip;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Horizontal row of cards — translateX set by JS */
    .fan-cards {
      position: relative;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 14px;
      width: max-content;
      will-change: transform;
      transition: none;
    }

    /* Reset fan positioning — JS drives transform */
    .fan-card {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      transition: none;
      will-change: transform;
      flex-shrink: 0;
    }

    .fan-card > div {
      height: 320px !important;
      width: 210px !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fan-stage {
      --progress: 1;
    }
    .fan-card {
      transition: none;
    }
  }
</style>

<script>
  const stage = document.querySelector<HTMLElement>('.fan-stage');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!stage || reducedMotion) {
    if (stage && reducedMotion) stage.style.setProperty('--progress', '1');
  } else if (window.innerWidth >= 640) {
    // ── Desktop / tablet: fan opens as stage enters viewport ──
    let frameId: number | null = null;

    const update = () => {
      frameId = null;
      const rect = stage.getBoundingClientRect();
      const vh = window.innerHeight || 1;
      const start = vh * 0.85;
      const end = vh * 0.25;
      let p = (start - rect.top) / (start - end);
      if (p < 0) p = 0;
      if (p > 1) p = 1;
      stage.style.setProperty('--progress', String(p));
    };

    const onScroll = () => { if (frameId === null) frameId = requestAnimationFrame(update); };
    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);

  } else {
    // ── Mobile: sticky panel, cards slide horizontally as page scrolls ──
    const fanCards = stage.querySelector<HTMLElement>('.fan-cards');
    const cards = Array.from(stage.querySelectorAll<HTMLElement>('.fan-card'));
    let frameId: number | null = null;

    const update = () => {
      frameId = null;
      const vh = window.innerHeight || 1;
      const scrolled = window.scrollY - stage.offsetTop;
      const total = stage.offsetHeight - vh;
      let p = total > 0 ? scrolled / total : 0;
      if (p < 0) p = 0;
      if (p > 1) p = 1;

      if (!fanCards || !cards.length) return;

      // Slide: first card centered at p=0, last card centered at p=1
      const viewW = stage.clientWidth;
      const cardW = cards[0].offsetWidth;
      const gap = 14;
      const totalW = cards.length * cardW + (cards.length - 1) * gap;
      const startX = (viewW - cardW) / 2;
      const endX = viewW / 2 - (totalW - cardW / 2);
      fanCards.style.transform = `translateX(${startX + (endX - startX) * p}px)`;

      // Per-card parallax: card closest to viewport center is full scale
      const viewCenterX = viewW / 2;
      cards.forEach((card) => {
        const rect = card.getBoundingClientRect();
        const dist = Math.abs(rect.left + rect.width / 2 - viewCenterX) / viewW;
        const scale = Math.max(0.88, 1 - dist * 0.1);
        card.style.transform = `scale(${scale.toFixed(3)})`;
      });
    };

    const onScroll = () => { if (frameId === null) frameId = requestAnimationFrame(update); };
    requestAnimationFrame(update);
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
  }
</script>
