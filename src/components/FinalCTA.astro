---
import { Icon } from 'astro-icon/components';

const VIDEO_SRC =
  'https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260505_110052_2e127257-5236-40b1-ba48-4690260f1185.mp4';
---

<section
  id="start"
  class="relative overflow-hidden px-6 py-32 text-white md:py-44"
>
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <video
      class="bg-video"
      data-src={VIDEO_SRC}
      autoplay
      muted
      loop
      playsinline
      preload="none"
      aria-hidden="true"></video>
    <div class="bg-tint absolute inset-0"></div>
  </div>

  <div class="bg-glow pointer-events-none absolute inset-0"></div>

  <div class="relative mx-auto max-w-3xl text-center">
    <p class="reveal font-mono mb-10 text-[10px] tracking-[0.3em] text-white/40 uppercase">
      — Begin
    </p>
    <h2
      class="cta-heading reveal font-serif mb-8 tracking-tight text-balance"
    >
      Your mind is with you<br /><em class="italic">every moment.</em>
    </h2>
    <p
      class="reveal mx-auto mb-12 max-w-xl text-base leading-relaxed text-pretty text-white/65 md:text-lg"
      style="transition-delay: 120ms;"
    >
      Learn how to make it your greatest ally.
    </p>
    <div class="reveal flex justify-center" style="transition-delay: 200ms;">
      <button
        id="start-practice-btn"
        type="button"
        class="inline-flex items-center gap-2 rounded-full bg-white px-8 py-4 text-sm font-medium text-black transition-all hover:bg-white/90 active:scale-[0.98]"
      >
        Start Your Practice
        <Icon name="lucide:arrow-right" size={16} stroke-width={2} />
      </button>
    </div>
  </div>
</section>

<style>
  .bg-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(65%);
  }

  .bg-tint {
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.3) 40%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .bg-glow {
    background: radial-gradient(
      ellipse 60% 60% at 50% 50%,
      rgba(255, 255, 255, 0.07) 0%,
      transparent 60%
    );
  }

  .cta-heading {
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    line-height: 1.05;
  }
</style>

<script>
  document.getElementById('start-practice-btn')?.addEventListener('click', () => {
    const modal = document.getElementById('contact-modal');
    if (modal) {
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
      (document.getElementById('modal-close') as HTMLElement | null)?.focus();
    }
  });
</script>
