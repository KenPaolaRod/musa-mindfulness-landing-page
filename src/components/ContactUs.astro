---
import { Icon } from 'astro-icon/components';

const contactDetails = [
  {
    icon: 'lucide:mail',
    label: 'Email',
    value: 'hello@asme.com',
    sub: 'We reply within 24 hours',
  },
  {
    icon: 'lucide:message-circle',
    label: 'Community',
    value: 'Join our Discord',
    sub: 'Connect with practitioners',
  },
  {
    icon: 'lucide:map-pin',
    label: 'Based in',
    value: 'San Francisco, CA',
    sub: 'Available worldwide',
  },
];
---

<section id="contact" class="contact-section relative overflow-hidden bg-black px-6 py-32 text-white md:py-44">

  <!-- Atmospheric background -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="contact-orb contact-orb--1"></div>
    <div class="contact-orb contact-orb--2"></div>
    <div class="contact-rings"></div>
    <div class="contact-noise"></div>
  </div>

  <div class="relative mx-auto max-w-6xl">

    <!-- Section label -->
    <p class="reveal font-mono mb-16 text-[10px] tracking-[0.3em] text-white/40 uppercase">
      — Contact Us
    </p>

    <div class="contact-grid">

      <!-- Left: copy + details -->
      <div class="contact-left">
        <h2 class="contact-heading reveal font-serif mb-8 tracking-tight">
          We're here<br /><em class="italic text-white/55">to listen.</em>
        </h2>
        <p class="reveal mb-14 max-w-sm text-base leading-relaxed text-white/60" style="transition-delay:80ms;">
          Every conversation matters. Reach out and a member
          of our team will respond with intention and care.
        </p>

        <div class="contact-cards" role="list">
          {contactDetails.map((item, i) => (
            <div
              class="contact-card reveal liquid-glass rounded-2xl"
              style={`transition-delay:${120 + i * 80}ms;`}
              role="listitem"
            >
              <div class="contact-card-icon">
                <Icon name={item.icon} size={18} stroke-width={1.5} />
              </div>
              <div>
                <p class="font-mono mb-0.5 text-[9px] tracking-[0.25em] text-white/35 uppercase">{item.label}</p>
                <p class="text-sm font-medium text-white/90">{item.value}</p>
                <p class="text-xs text-white/45">{item.sub}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: form -->
      <div class="reveal contact-form-wrap" style="transition-delay:200ms;">
        <div class="contact-form-card liquid-glass rounded-3xl">

          <p class="font-mono mb-8 text-[9px] tracking-[0.3em] text-white/35 uppercase">Send a message</p>

          <form class="contact-form" novalidate>

            <div class="field-row">
              <div class="field-group">
                <label for="cf-name" class="field-label">Name</label>
                <div class="field-wrap">
                  <input
                    id="cf-name"
                    name="name"
                    type="text"
                    class="field-input"
                    placeholder="Your name"
                    autocomplete="name"
                    required
                  />
                  <span class="field-line" aria-hidden="true"></span>
                </div>
              </div>

              <div class="field-group">
                <label for="cf-email" class="field-label">Email</label>
                <div class="field-wrap">
                  <input
                    id="cf-email"
                    name="email"
                    type="email"
                    class="field-input"
                    placeholder="you@email.com"
                    autocomplete="email"
                    required
                  />
                  <span class="field-line" aria-hidden="true"></span>
                </div>
              </div>
            </div>

            <div class="field-group">
              <label for="cf-subject" class="field-label">Subject</label>
              <div class="field-wrap">
                <input
                  id="cf-subject"
                  name="subject"
                  type="text"
                  class="field-input"
                  placeholder="What would you like to talk about?"
                  required
                />
                <span class="field-line" aria-hidden="true"></span>
              </div>
            </div>

            <div class="field-group field-group--textarea">
              <label for="cf-message" class="field-label">Message</label>
              <div class="field-wrap">
                <textarea
                  id="cf-message"
                  name="message"
                  class="field-input field-textarea"
                  placeholder="Tell us what's on your mind..."
                  rows="5"
                  required
                ></textarea>
                <span class="field-line" aria-hidden="true"></span>
              </div>
            </div>

            <div class="form-footer">
              <p class="form-note font-mono text-[9px] tracking-[0.2em] text-white/30 uppercase">
                We reply within 24 hours
              </p>
              <button type="submit" class="submit-btn" aria-label="Send message">
                <span class="submit-label">Send</span>
                <span class="submit-icon" aria-hidden="true">
                  <Icon name="lucide:send" size={14} stroke-width={1.75} />
                </span>
              </button>
            </div>

          </form>

          <!-- Success state (hidden by default) -->
          <div class="form-success" aria-live="polite" aria-atomic="true" hidden>
            <div class="success-icon">
              <Icon name="lucide:check" size={22} stroke-width={1.5} />
            </div>
            <p class="font-serif text-xl italic text-white/85">Thank you for reaching out.</p>
            <p class="mt-2 text-sm text-white/50">We'll get back to you with care.</p>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Layout ── */
  .contact-grid {
    display: grid;
    gap: 4rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: 5rem;
    }
  }

  /* ── Atmospheric BG ── */
  .contact-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(90px);
    opacity: 0.28;
  }
  .contact-orb--1 {
    width: 520px;
    height: 520px;
    top: -80px;
    right: -100px;
    background: radial-gradient(circle, rgba(255,255,255,0.14) 0%, transparent 70%);
    animation: orb-drift 18s ease-in-out infinite alternate;
  }
  .contact-orb--2 {
    width: 400px;
    height: 400px;
    bottom: -60px;
    left: -80px;
    background: radial-gradient(circle, rgba(200,220,255,0.10) 0%, transparent 70%);
    animation: orb-drift 24s ease-in-out infinite alternate-reverse;
  }

  @keyframes orb-drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(30px, 20px) scale(1.06); }
  }

  .contact-rings {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: transparent;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.028),
      0 0 0 80px rgba(255,255,255,0.012),
      0 0 0 160px rgba(255,255,255,0.008),
      0 0 0 240px rgba(255,255,255,0.005);
    pointer-events: none;
  }

  .contact-noise {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px;
    pointer-events: none;
  }

  /* ── Heading ── */
  .contact-heading {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.05;
  }

  /* ── Contact cards ── */
  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .contact-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.125rem 1.375rem;
    transition: background 250ms ease, transform 250ms ease;
  }
  .contact-card:hover {
    background: rgba(255,255,255,0.04);
    transform: translateX(4px);
  }

  .contact-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.07);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── Form card ── */
  .contact-form-card {
    padding: 2.25rem;
    border-radius: 1.5rem;
  }

  @media (min-width: 640px) {
    .contact-form-card {
      padding: 2.75rem;
    }
  }

  /* ── Fields ── */
  .field-row {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 480px) {
    .field-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .field-group {
    margin-bottom: 1.5rem;
  }
  .field-group--textarea {
    margin-bottom: 2rem;
  }
  .field-row .field-group {
    margin-bottom: 0;
  }

  .field-label {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.625rem;
    user-select: none;
  }

  .field-wrap {
    position: relative;
  }

  .field-input {
    display: block;
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: rgba(255,255,255,0.88);
    font-size: 0.9375rem;
    line-height: 1.5;
    padding: 0.5rem 0 0.625rem;
    caret-color: rgba(255,255,255,0.7);
    resize: none;
    box-sizing: border-box;
  }

  .field-input::placeholder {
    color: rgba(255,255,255,0.22);
  }

  .field-textarea {
    min-height: 7rem;
    resize: none;
  }

  .field-line {
    display: block;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255,255,255,0.13);
    transition: background 300ms ease;
    pointer-events: none;
  }

  .field-wrap:focus-within .field-line {
    background: rgba(255,255,255,0.45);
  }

  .field-wrap:focus-within .field-input::placeholder {
    color: rgba(255,255,255,0.14);
  }

  /* ── Form footer ── */
  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Submit button ── */
  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: none;
    cursor: pointer;
    background: #fff;
    color: #000;
    border-radius: 9999px;
    padding: 0.75rem 1.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: background 200ms ease, transform 150ms ease, box-shadow 200ms ease;
    position: relative;
    overflow: hidden;
  }

  .submit-btn:hover {
    background: rgba(255,255,255,0.92);
    transform: translateY(-1px);
    box-shadow: 0 8px 28px rgba(255,255,255,0.12);
  }
  .submit-btn:active {
    transform: scale(0.97);
  }

  .submit-icon {
    display: flex;
    align-items: center;
    transition: transform 250ms ease;
  }
  .submit-btn:hover .submit-icon {
    transform: translateX(3px);
  }

  /* ── Success state ── */
  .form-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem 2rem;
    gap: 0.5rem;
  }
  .form-success[hidden] {
    display: none;
  }

  .success-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    margin-bottom: 1rem;
    animation: pop-in 400ms cubic-bezier(0.34,1.56,0.64,1) both;
  }

  @keyframes pop-in {
    from { transform: scale(0.5); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-orb--1,
    .contact-orb--2 { animation: none; }
    .success-icon   { animation: none; }
  }
</style>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Reveal on scroll ── */
  if (!reduceMotion && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -60px 0px' },
    );
    document
      .querySelectorAll('#contact .reveal')
      .forEach((el) => io.observe(el));
  } else {
    document
      .querySelectorAll('#contact .reveal')
      .forEach((el) => el.classList.add('in'));
  }

  /* ── Form submit ── */
  const form = document.querySelector<HTMLFormElement>('#contact .contact-form');
  const success = document.querySelector<HTMLElement>('#contact .form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    // Simulate async send
    const btn = form.querySelector<HTMLButtonElement>('.submit-btn');
    if (btn) {
      btn.disabled = true;
      btn.style.opacity = '0.6';
    }
    setTimeout(() => {
      form.hidden = true;
      if (success) success.hidden = false;
    }, 600);
  });
</script>
